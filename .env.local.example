# ══════════════════════════════════════════════════════
# GitWhisper AI — Environment Variables
# ══════════════════════════════════════════════════════

# ── Groq (FREE — Primary analysis engine) ──────────────
# Get free key: https://console.groq.com → API Keys
NEXT_PUBLIC_GROQ_API_KEY=your-groq-api-key-here

# ── Gemini (optional fallback) ──────────────────────────
# Get free key: https://aistudio.google.com/app/apikey
NEXT_PUBLIC_GEMINI_API_KEY=your-gemini-api-key-here

# ── GitHub Token (optional — increases rate limit) ──────
# Leave BLANK if you don't have one
NEXT_PUBLIC_GITHUB_TOKEN=

# ── Supabase ─────────────────────────────────────────────
# Get from: https://supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Contact Form (Formspree) ────────────────────────────
# Get from: https://formspree.io → your form endpoint
NEXT_PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/your-form-id

# ── Backend (optional Python API) ───────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
